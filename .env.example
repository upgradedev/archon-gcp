# Conversational agent (ADK + Gemini via Google AI Studio). The deterministic
# books + tests run WITHOUT any of this.
GOOGLE_API_KEY=your_ai_studio_key_here
GEMINI_MODEL=gemini-2.0-flash

# GCP-native persistence (optional — omit to use the local in-memory store).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
ARCHON_GCS_BUCKET=your-archon-bucket
